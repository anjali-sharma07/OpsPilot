# ── Backend (FastAPI on Render) ───────────────────────────────────────────────
GROQ_API_KEY=your-groq-api-key-here
DATABASE_URL=sqlite:///./opspilot.db
CHROMA_DB_PATH=./chroma_db
EMBEDDING_MODEL=all-MiniLM-L6-v2
GROQ_MODEL=llama-3.3-70b-versatile
CHUNK_SIZE=800
CHUNK_OVERLAP=100
UPLOAD_DIRECTORY=./uploads

# ── Frontend (React/Vite on Vercel) ──────────────────────────────────────────
# Local development: leave blank — the Vite dev proxy forwards /upload and /chat
# to 127.0.0.1:8001 automatically.
# Vercel production: set this in the Vercel project dashboard under
#   Settings → Environment Variables → VITE_API_URL
#   Value: https://opspilot-backend-xa1t.onrender.com
VITE_API_URL=https://opspilot-backend-xa1t.onrender.com